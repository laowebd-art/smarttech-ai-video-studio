# ============================================================================
# Frontend (Vite) — safe to expose in the browser. Only VITE_-prefixed vars
# are bundled into client code; everything else below stays server-side.
# ============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_APP_NAME=SmartTech AI Studio
VITE_DEFAULT_LANGUAGE=en

# Base URL of the Express API server below. Defaults to localhost in dev;
# set this to your deployed server URL in production.
VITE_API_BASE_URL=http://localhost:8787

# ============================================================================
# Server (server/) — NEVER prefix these with VITE_, and never commit real
# values. These are only read by server/index.ts (Node/Express), not by the
# browser bundle.
#
# NOTE: there is no AI_PROVIDER or TTS_PROVIDER switch anymore. Which
# provider serves a request is decided by the AI Router at runtime, using
# the `provider_configs` table (priority + enabled per capability) — see
# supabase/seed/provider_configs.sql and ARCHITECTURE.md. Set whichever
# provider keys below you actually have; the router automatically skips any
# provider whose keys are missing and falls back to the next configured one.
# ============================================================================
PORT=8787
CORS_ORIGIN=http://localhost:5173

# Supabase service_role key — full-access, server-only. Used to verify user
# sessions, write ai_usage_logs, and read provider_configs. Find it in
# Project Settings > API.
SUPABASE_SERVICE_ROLE_KEY=

# ---- Text generation (script writing, scene breakdown, captions, translation) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# ---- Voice generation (Phase 3 + AI Voice Studio) ----
OPENAI_TTS_MODEL=tts-1
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Default ElevenLabs voice. ElevenLabs voice IDs are account-specific, so
# there's no universal style mapping like OpenAI's stock voices — set one
# default, or override per style with ELEVENLABS_VOICE_ID_CALM / _SERIOUS /
# _EMOTIONAL / _ENERGETIC / _DOCUMENTARY / _FRIENDLY
ELEVENLABS_VOICE_ID=

# ---- Video generation (AI Video Studio: text-to-video, image-to-video) ----
# Kling — official API uses a short-lived JWT signed with an Access Key /
# Secret Key pair (see server/lib/adapters/video/klingVideoAdapter.ts).
KLING_ACCESS_KEY=
KLING_SECRET_KEY=
KLING_API_BASE_URL=https://api.klingai.com
KLING_MODEL=kling-v1

# Google Veo — via the Gemini API (simplest path; no GCP service account
# needed). Get a key from Google AI Studio.
GOOGLE_VEO_API_KEY=
GOOGLE_VEO_MODEL=veo-3.0-generate-preview
GOOGLE_VEO_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# Runway — official API, Bearer token + version header.
RUNWAY_API_KEY=
RUNWAY_MODEL=gen4_turbo
RUNWAY_API_BASE_URL=https://api.dev.runwayml.com/v1

# ---- Optional stock/visual providers (Phase 4) ----
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
