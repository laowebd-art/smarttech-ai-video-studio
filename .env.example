# ============================================================================
# Frontend (Vite) — safe to expose in the browser. Only VITE_-prefixed vars
# are bundled into client code; everything else below stays server-side.
# ============================================================================
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
VITE_APP_NAME=SmartTech AI Video Studio
VITE_DEFAULT_LANGUAGE=en

# Base URL of the Express API server below. Defaults to localhost in dev;
# set this to your deployed server URL in production.
VITE_API_BASE_URL=http://localhost:8787

# ============================================================================
# Server (server/) — NEVER prefix these with VITE_, and never commit real
# values. These are only read by server/index.ts (Node/Express), not by the
# browser bundle.
# ============================================================================
PORT=8787
CORS_ORIGIN=http://localhost:5173

# Supabase service_role key — full-access, server-only. Used to verify user
# sessions and write ai_usage_logs. Find it in Project Settings > API.
SUPABASE_SERVICE_ROLE_KEY=

# Which AI provider powers script generation, scene breakdown, and captions.
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

# Text-to-Speech provider (Phase 3)
TTS_PROVIDER=openai
OPENAI_TTS_MODEL=tts-1
ELEVENLABS_API_KEY=
ELEVENLABS_MODEL_ID=eleven_multilingual_v2
# Default ElevenLabs voice (required if TTS_PROVIDER=elevenlabs). ElevenLabs
# voice IDs are account-specific, so there's no universal style mapping like
# OpenAI's stock voices — set one default, or override per style with
# ELEVENLABS_VOICE_ID_CALM / _SERIOUS / _EMOTIONAL / _ENERGETIC / _DOCUMENTARY / _FRIENDLY
ELEVENLABS_VOICE_ID=

# Optional stock/visual providers (Phase 4)
PEXELS_API_KEY=
PIXABAY_API_KEY=
UNSPLASH_ACCESS_KEY=
